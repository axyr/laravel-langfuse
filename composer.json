{
    "name": "axyr/laravel-langfuse",
    "description": "Langfuse PHP SDK for Laravel",
    "type": "library",
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^12.0|^13.0",
        "illuminate/http": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Axyr\\Langfuse\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "Laravel\\Ai\\": "tests/Stubs/LaravelAi/",
            "NeuronAI\\": "tests/Stubs/NeuronAi/"
        }
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^4.0",
        "phpmd/phpmd": "^2.0",
        "prism-php/prism": "^0.100"
    },
    "suggest": {
        "laravel/ai": "Required for automatic Laravel AI SDK tracing (^0.4)",
        "neuron-core/neuron-ai": "Required for automatic Neuron AI agent tracing (^3.0)",
        "prism-php/prism": "Required for automatic Prism LLM call tracing (^0.100)"
    },
    "scripts": {
        "test": "pest",
        "test:arch": "pest --filter=arch",
        "analyse": "phpstan analyse",
        "format": "pint",
        "format:test": "pint --test",
        "complexity": "phpmd src text phpmd.xml 2>&1 | grep -v 'Deprecated:' | grep -v 'PHP Deprecated:' || true",
        "quality": [
            "@format:test",
            "@analyse",
            "@complexity",
            "@test"
        ],
        "post-install-cmd": [
            "@install-hooks"
        ],
        "post-update-cmd": [
            "@install-hooks"
        ],
        "install-hooks": [
            "bash -c 'if [ -d .git ]; then cp hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit && echo \"Pre-commit hook installed\"; fi'"
        ]
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "extra": {
        "laravel": {
            "providers": [
                "Axyr\\Langfuse\\LangfuseServiceProvider"
            ],
            "aliases": {
                "Langfuse": "Axyr\\Langfuse\\LangfuseFacade"
            }
        }
    }
}
